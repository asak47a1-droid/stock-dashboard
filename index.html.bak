<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>台股看板</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #111110;
      --bg2: #1a1a18;
      --bg3: #222220;
      --text: #f1efe8;
      --text2: #b4b2a9;
      --text3: #888780;
      --border: rgba(255,255,255,0.1);
      --border2: rgba(255,255,255,0.18);
      --radius-md: 8px;
      --radius-lg: 12px;
      --up: #e05252;
      --down: #3db87a;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Noto Sans TC", sans-serif;
      min-height: 100vh;
      padding: 1.5rem 1rem;
    }

    .container { max-width: 900px; margin: 0 auto; }

    /* Header */
    .header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.5rem;
    }
    .header h1 {
      font-size: 18px;
      font-weight: 500;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .header h1 i { font-size: 18px; color: var(--text2); }
    .update-info { font-size: 12px; color: var(--text3); }
    .refresh-btn {
      background: transparent;
      border: 0.5px solid var(--border2);
      color: var(--text2);
      border-radius: var(--radius-md);
      padding: 5px 12px;
      font-size: 12px;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 5px;
      transition: background 0.15s;
    }
    .refresh-btn:hover { background: var(--bg3); }

    /* Cards */
    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 10px;
      margin-bottom: 1.25rem;
    }
    .card {
      background: var(--bg2);
      border-radius: var(--radius-lg);
      padding: 14px 16px;
      cursor: pointer;
      border: 0.5px solid transparent;
      transition: border-color 0.15s;
    }
    .card:hover { border-color: var(--border2); }
    .card.selected { border-color: #378add; }
    .card-symbol { font-size: 11px; color: var(--text3); margin-bottom: 2px; }
    .card-name { font-size: 13px; font-weight: 500; color: var(--text); margin-bottom: 8px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .card-price { font-size: 22px; font-weight: 500; margin-bottom: 4px; }
    .card-change { font-size: 13px; }
    .card-skeleton { opacity: 0.3; }
    .up { color: var(--up); }
    .down { color: var(--down); }
    .flat { color: var(--text2); }

    /* Chart */
    .chart-area {
      background: var(--bg2);
      border-radius: var(--radius-lg);
      padding: 16px 18px;
    }
    .chart-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 14px;
    }
    .chart-title { font-size: 14px; font-weight: 500; }
    .range-tabs { display: flex; gap: 4px; }
    .range-tab {
      padding: 4px 12px;
      border-radius: var(--radius-md);
      border: 0.5px solid var(--border);
      background: transparent;
      font-size: 12px;
      color: var(--text2);
      cursor: pointer;
      transition: all 0.15s;
    }
    .range-tab:hover { background: var(--bg3); }
    .range-tab.active {
      background: var(--bg3);
      color: var(--text);
      border-color: var(--border2);
    }
    .chart-wrap { position: relative; width: 100%; height: 280px; }
    .chart-note { font-size: 11px; color: var(--text3); text-align: right; margin-top: 8px; }

    /* Loading / Error */
    .status-msg {
      text-align: center;
      padding: 3rem 1rem;
      font-size: 13px;
      color: var(--text3);
    }
    .error { color: #e05252; }

    @media (max-width: 480px) {
      .cards { grid-template-columns: repeat(2, 1fr); }
      .card-price { font-size: 18px; }
    }
  </style>
</head>
<body>
<div class="container">

  <div class="header">
    <h1>
      <i class="ti ti-chart-line" aria-hidden="true"></i>
      台股看板
    </h1>
    <div style="display:flex;align-items:center;gap:10px">
      <span class="update-info" id="lastUpdate">資料載入中...</span>
      <button class="refresh-btn" onclick="refresh()">
        <i class="ti ti-refresh" aria-hidden="true"></i> 更新
      </button>
    </div>
  </div>

  <div class="cards" id="cards" aria-label="股票報價卡片"></div>

  <div class="chart-area">
    <div class="chart-header">
      <span class="chart-title" id="chartTitle">歷史走勢</span>
      <div class="range-tabs" role="group" aria-label="時間區間">
        <button class="range-tab active" onclick="setRange(this,'1mo')">1M</button>
        <button class="range-tab" onclick="setRange(this,'3mo')">3M</button>
        <button class="range-tab" onclick="setRange(this,'6mo')">6M</button>
        <button class="range-tab" onclick="setRange(this,'1y')">1Y</button>
      </div>
    </div>
    <div class="chart-wrap">
      <canvas id="lineChart" role="img" aria-label="歷史走勢折線圖"></canvas>
    </div>
    <p class="chart-note">資料來源：Yahoo Finance｜延遲約 15 分鐘</p>
  </div>

</div>

<script>
const stocks = [
  { symbol: '2330.TW', name: '台積電',        short: 'TSMC'   },
  { symbol: '0050.TW', name: '元大台灣50',     short: '0050'   },
  { symbol: '00878.TW', name: '國泰永續高股息', short: '00878'  },
  { symbol: '00692.TW', name: '富邦公司治理',  short: '00692'  },
  { symbol: '006208.TW', name: '富邦台50',     short: '006208' },
];

const PROXY = '/api/';
let selectedIdx = 0;
let currentRange = '1mo';
let lineChart = null;
let priceData = {};

/* ── helpers ─────────────────────────────────── */
function cc(v) { return v > 0 ? 'up' : v < 0 ? 'down' : 'flat'; }
function ar(v) { return v > 0 ? '▲' : v < 0 ? '▼' : '—'; }
function fmt(n, d=2) { return n != null ? n.toFixed(d) : '—'; }

/* ── cards ───────────────────────────────────── */
function renderCards() {
  document.getElementById('cards').innerHTML = stocks.map((s, i) => {
    const d = priceData[s.symbol];
    const price   = d ? fmt(d.price) : '—';
    const chg     = d ? (d.change >= 0 ? '+' : '') + fmt(d.change) : '—';
    const pct     = d ? (d.pct >= 0 ? '+' : '') + fmt(d.pct) + '%' : '';
    const cls     = d ? cc(d.change) : 'flat card-skeleton';
    return `
      <div class="card ${selectedIdx===i?'selected':''}" onclick="selectStock(${i})" role="button" tabindex="0" aria-label="${s.name} 目前股價 ${price}">
        <div class="card-symbol">${s.short}</div>
        <div class="card-name">${s.name}</div>
        <div class="card-price ${cls}">${price}</div>
        <div class="card-change ${cls}">${ar(d?.change)} ${chg} ${pct}</div>
      </div>`;
  }).join('');
}

/* ── fetch price ─────────────────────────────── */
async function fetchPrice(symbol) {
  const url = `https://query1.finance.yahoo.com/v8/finance/chart/${symbol}?interval=1d&range=1d`;
  try {
    const r = await fetch(PROXY + url.replace('https://query1.finance.yahoo.com/', ''));
    const j = await r.json();
    const meta = j.chart.result[0].meta;
    const price = meta.regularMarketPrice;
    const prev  = meta.chartPreviousClose ?? meta.previousClose ?? price;
    const change = price - prev;
    const pct   = prev ? (change / prev) * 100 : 0;
    return { price, change, pct };
  } catch { return null; }
}

/* ── fetch history ───────────────────────────── */
async function fetchHistory(symbol, range) {
  const iv = { '1mo':'1d', '3mo':'1d', '6mo':'1wk', '1y':'1wk' }[range] ?? '1d';
  const url = `https://query1.finance.yahoo.com/v8/finance/chart/${symbol}?interval=${iv}&range=${range}`;
  try {
    const r = await fetch(PROXY + url.replace('https://query1.finance.yahoo.com/', ''));
    const j = await r.json();
    const res    = j.chart.result[0];
    const stamps = res.timestamp;
    const closes = res.indicators.quote[0].close;
    const labels = stamps.map(t => {
      const d = new Date(t * 1000);
      return `${d.getMonth()+1}/${d.getDate()}`;
    });
    return { labels, data: closes.map(v => v != null ? +v.toFixed(2) : null) };
  } catch { return null; }
}

/* ── chart ───────────────────────────────────── */
function renderChart(labels, data, name) {
  const valid = data.filter(Boolean);
  const first = valid[0] ?? 0, last = valid[valid.length-1] ?? 0;
  const isUp  = last >= first;
  const lineColor = isUp ? '#e05252' : '#3db87a';
  const fillColor = isUp ? 'rgba(224,82,82,0.12)' : 'rgba(61,184,122,0.12)';

  if (lineChart) { lineChart.destroy(); lineChart = null; }

  const ctx = document.getElementById('lineChart');
  ctx.setAttribute('aria-label', `${name} ${currentRange} 歷史走勢`);

  lineChart = new Chart(ctx, {
    type: 'line',
    data: {
      labels,
      datasets: [{
        label: name,
        data,
        borderColor: lineColor,
        backgroundColor: fillColor,
        borderWidth: 2,
        pointRadius: 0,
        pointHoverRadius: 4,
        fill: true,
        tension: 0.3,
        spanGaps: true,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: '#222220',
          titleColor: '#b4b2a9',
          bodyColor: '#f1efe8',
          borderColor: '#333',
          borderWidth: 0.5,
          callbacks: { label: c => ` ${c.parsed.y?.toFixed(2) ?? '—'}` }
        }
      },
      scales: {
        x: {
          ticks: { color: '#888780', font: { size: 11 }, maxTicksLimit: 8, autoSkip: true },
          grid: { color: 'rgba(255,255,255,0.05)' }
        },
        y: {
          ticks: { color: '#888780', font: { size: 11 } },
          grid: { color: 'rgba(255,255,255,0.05)' },
          position: 'right'
        }
      }
    }
  });
}

/* ── actions ─────────────────────────────────── */
async function loadChart() {
  const s = stocks[selectedIdx];
  document.getElementById('chartTitle').textContent = `${s.name} 歷史走勢`;
  const hist = await fetchHistory(s.symbol, currentRange);
  if (hist) renderChart(hist.labels, hist.data, s.name);
}

async function selectStock(i) {
  selectedIdx = i;
  renderCards();
  await loadChart();
}

function setRange(el, range) {
  currentRange = range;
  document.querySelectorAll('.range-tab').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
  loadChart();
}

async function refresh() {
  renderCards();
  await Promise.all(stocks.map(async s => {
    const d = await fetchPrice(s.symbol);
    if (d) priceData[s.symbol] = d;
  }));
  renderCards();
  const now = new Date();
  document.getElementById('lastUpdate').textContent =
    `更新：${now.getHours().toString().padStart(2,'0')}:${now.getMinutes().toString().padStart(2,'0')}`;
  await loadChart();
}

/* ── init ────────────────────────────────────── */
refresh();
</script>
</body>
</html>
